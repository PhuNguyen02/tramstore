# ═══════════════════════════════════════════════════════════
# 🔧 TramStore Backend - Environment Configuration (Example)
# ═══════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database (MySQL) ────────────────────────────────────
DATABASE_URL="mysql://root:root@localhost:3306/tramstore"

# ─── JWT Authentication ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
