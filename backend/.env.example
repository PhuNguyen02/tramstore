# ═══════════════════════════════════════════════════════════
# 🔧 TramStore Backend - Environment Configuration (Example)
# ═══════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database (MySQL) ────────────────────────────────────
DATABASE_URL="mysql://root:root@localhost:3306/tramstore"

# ─── JWT Authentication ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
# ─── VietQR & SePay ───────────────────────────────────────
# VietQR & SePay
VIETQR_BANK_BIN=970422            # MB Bank (giữ nguyên)
VIETQR_ACCOUNT_NUMBER=7500121279777
VIETQR_ACCOUNT_NAME=NGUYEN HAI PHU
VIETQR_TEMPLATE=compact2          # Bạn có thể thử 'qr_only' hoặc 'compact' nếu muốn

# SePay Webhook Secret
SEPAY_WEBHOOK_SECRET=your_api_key_from_dashboard
