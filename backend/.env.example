# ═══════════════════════════════════════════════════════════
# 🔧 DigiMarket Backend - Environment Configuration
# ═══════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database (MySQL via Prisma) ──────────────────────────
DATABASE_URL="mysql://digimarket_user:digimarket_pass_2024@localhost:3306/digimarket"
MYSQL_ROOT_PASSWORD=digimarket_root_2024
MYSQL_DATABASE=digimarket
MYSQL_USER=digimarket_user
MYSQL_PASSWORD=digimarket_pass_2024

# ─── Redis Cache ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=digimarket_redis_2024

# ─── JWT Authentication ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ─── File Upload / Storage ────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ─── Mail (Optional) ─────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM="DigiMarket <noreply@digimarket.com>"

# ─── Payment (Optional) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
