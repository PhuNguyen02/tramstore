# ═══════════════════════════════════════════════════════════
# 🔧 TramStore - Global Environment Configuration
# ═══════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────
NODE_ENV=production

# ─── Database (MySQL) ────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=tramstore
# URL cho backend kết nối tới DB container
DATABASE_URL=mysql://root:root@mysql:3306/tramstore

# ─── Backend (NestJS API) ────────────────────────────────
BACKEND_PORT=4000
API_PREFIX=api/v1

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS (Domain của Frontend)
CORS_ORIGIN=http://localhost:3000

# ─── Frontend (Next.js) ──────────────────────────────────
FRONTEND_PORT=3000
# API URL mà Frontend sẽ gọi tới
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
