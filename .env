# ═══════════════════════════════════════════════════════════
# 🔧 TramStore - Global Environment Configuration
# ═══════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────
NODE_ENV=production

# ─── Database (SQLite) ──────────────────────────────────
# Lưu ý: Trong Docker, volume sẽ được mount vào /app/data
DATABASE_URL="file:/app/data/dev.db"

# ─── Backend (NestJS API) ────────────────────────────────
BACKEND_PORT=4000
API_PREFIX=api/v1

# JWT Auth
JWT_SECRET=TramStoreSecret2026!
JWT_EXPIRES_IN=7d

# CORS (Domain của Frontend hoặc * để test nhanh trên VPS)
CORS_ORIGIN=*

# ─── Frontend (Next.js) ──────────────────────────────────
FRONTEND_PORT=3000
# QUAN TRỌNG: Thay localhost bằng IP của VPS hoặc domain của bạn khi deploy
NEXT_PUBLIC_API_URL=http://103.69.96.183:4000/api/v1
